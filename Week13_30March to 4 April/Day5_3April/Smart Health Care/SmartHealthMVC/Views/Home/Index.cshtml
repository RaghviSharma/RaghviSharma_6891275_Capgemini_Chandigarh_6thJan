<div class="container d-flex justify-content-center align-items-center" style="height: 90vh;">

    <div class="card text-center shadow-lg border-0 rounded-4 p-4" style="max-width: 600px;">

        <div class="card-body">

            <h1 class="fw-bold mb-3 text-primary">
                Smart Health Care
            </h1>

            <p class="lead text-muted mb-4">
                Manage patients, doctors, and appointments easily in one place.
            </p>

            <div class="d-flex justify-content-center gap-3">

                <a asp-controller="Patient" asp-action="Create" class="btn btn-primary btn-lg px-4">
                    Get Started
                </a>

                <a asp-controller="Appointments" asp-action="Create" class="btn btn-outline-primary btn-lg px-4">
                    Book Appointment
                </a>

            </div>

        </div>

    </div>

</div>