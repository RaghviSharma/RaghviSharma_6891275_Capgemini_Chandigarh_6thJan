@model SmartHealthcare.Models.DTOs.CreateBillDTO
@{
    ViewData["Title"] = "Generate Bill";
    var appointment = ViewBag.Appointment as SmartHealthcare.Models.DTOs.AppointmentDTO;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-info text-white p-4">
                    <h3 class="mb-0"><i class="bi bi-receipt"></i> Generate Bill</h3>
                </div>
                <div class="card-body p-4">
                    @if (appointment != null)
                    {
                        <div class="alert alert-info">
                            <strong>Appointment:</strong> @appointment.Id - @appointment.PatientName with Dr. @appointment.DoctorName
                        </div>
                    }

                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="AppointmentId" />

                        <div class="mb-3">
                            <label asp-for="ConsultationFee" class="form-label">Consultation Fee <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="ConsultationFee" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="ConsultationFee" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MedicineCharges" class="form-label">Medicine Charges <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="MedicineCharges" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="MedicineCharges" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PaymentStatus" class="form-label">Payment Status <span class="text-danger">*</span></label>
                            <select asp-for="PaymentStatus" class="form-select">
                                <option value="Unpaid">Unpaid</option>
                                <option value="Paid">Paid</option>
                            </select>
                            <span asp-validation-for="PaymentStatus" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-info">
                                <i class="bi bi-check-circle"></i> Generate Bill
                            </button>
                            <a href="@Url.Action("Details", "Appointment", new { id = Model.AppointmentId })" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>