<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Healthcare</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #020617, #0f172a);
            color: white;
        }

        /* NAVBAR */
        .app-navbar {
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .nav-link {
            color: #cbd5f5 !important;
        }

        .nav-link:hover {
            color: #38bdf8 !important;
        }

        /* BUTTONS */
        .btn-light {
            background: linear-gradient(45deg, #22d3ee, #6366f1);
            border: none;
            color: white;
        }

        .btn-outline-light {
            border-color: #22d3ee;
            color: #22d3ee;
        }

        .btn-outline-light:hover {
            background: #22d3ee;
            color: black;
        }

        /* MAIN CONTAINER */
        .main-shell .container {
            background: rgba(255,255,255,0.03);
            border-radius: 16px;
            padding: 30px;
            backdrop-filter: blur(10px);
        }

        /* 🔥 GLOBAL CARD FIX */
        .card {
            background: #111827 !important;
            color: white !important;
            border-radius: 16px;
            border: none;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }

        .card h1, 
        .card h2, 
        .card h3, 
        .card h4, 
        .card h5, 
        .card p {
            color: white !important;
        }

        /* HERO FIX */
        .hero-box {
            background: linear-gradient(135deg, #1e293b, #020617);
            color: white;
            border-radius: 16px;
            padding: 30px;
        }

        /* ALERTS */
        .alert {
            border-radius: 12px;
        }

        /* FOOTER */
        .app-footer {
            background: rgba(2, 6, 23, 0.9);
            padding: 15px 0;
        }

        /* SMOOTH UI */
        * {
            transition: 0.2s;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark app-navbar">
        <div class="container">

            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-heart-pulse text-info"></i> Smart Healthcare
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navBar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navBar">
                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    @if (Context.Session.GetString("Token") != null)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Appointment" asp-action="Index">Appointments</a></li>

                        @if (Context.Session.GetString("Role") == "Patient")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Patient" asp-action="Billing">Billing</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Patient" asp-action="MedicalHistory">Prescriptions</a></li>
                        }

                        <li class="nav-item"><a class="nav-link" asp-controller="Patient" asp-action="Profile">Profile</a></li>
                    }
                </ul>

                <div class="d-flex gap-2">

                    @if (Context.Session.GetString("Token") != null)
                    {
                        <span class="text-info small">@Context.Session.GetString("FullName")</span>
                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Logout">Logout</a>
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                        <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Register">Register</a>
                    }

                </div>
            </div>
        </div>
    </nav>

    <!-- MAIN -->
    <main class="main-shell">
        <div class="container py-4">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            @if (TempData["Info"] != null)
            {
                <div class="alert alert-info">@TempData["Info"]</div>
            }

            @RenderBody()

        </div>
    </main>

    <!-- FOOTER -->
    <footer class="app-footer text-center text-white">
        <div class="container">
            <p class="mb-1">&copy; 2026 Smart Healthcare</p>
            <small class="text-white-50">Modern Healthcare Management System</small>
        </div>
    </footer>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>