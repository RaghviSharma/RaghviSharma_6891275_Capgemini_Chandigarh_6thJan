@model List<Product>

@{
    ViewData["Title"] = "Products";
}

<h2>Products</h2>
<a class="btn btn-success mb-3" asp-action="Create">Add Product</a>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Categories</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Id</td>
                <td>@p.Name</td>
                <td>@(p.Categories != null ? string.Join(", ", p.Categories) : "-")</td>
            </tr>
        }
    </tbody>
</table>