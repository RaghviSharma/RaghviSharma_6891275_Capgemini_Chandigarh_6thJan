@model MVCDemoBook_ASP.Models.BookModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this book?</h3>

<div>
    <h4>Book Details</h4>
    <hr />

    ```
    <dl class="row">

        <dt class="col-sm-2">
            Book Name
        </dt>
        <dd class="col-sm-10">
            @Model.BookName
        </dd>

        <dt class="col-sm-2">
            Author
        </dt>
        <dd class="col-sm-10">
            @Model.Author
        </dd>

        <dt class="col-sm-2">
            Price
        </dt>
        <dd class="col-sm-10">
            @Model.Price
        </dd>

        <dt class="col-sm-2">
            Pages
        </dt>
        <dd class="col-sm-10">
            @Model.Pages
        </dd>

        <dt class="col-sm-2">
            Description
        </dt>
        <dd class="col-sm-10">
            @Model.Description
        </dd>

    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="BookId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
    

</div>
