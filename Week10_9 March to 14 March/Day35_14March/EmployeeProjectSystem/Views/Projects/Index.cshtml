@model IEnumerable<EmployeeProjectSystem.Models.Project>

<h2>Projects</h2>

<a asp-action="Create">Add Project</a>

<table border="1">

	<tr>
		<th>Title</th>
		<th>Actions</th>
	</tr>

	@foreach (var item in Model)
	{
		<tr>

			<td>@item.Title</td>

			<td>

				<a asp-action="Edit" asp-route-id="@item.ProjectId">Edit</a>
				<a asp-action="Delete" asp-route-id="@item.ProjectId">Delete</a>

			</td>

		</tr>
	}

</table>