@model IEnumerable<EmployeeProjectSystem.Models.Employee>

<h2 class="mb-3">Employees</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Add Employee</a>

<table class="table table-bordered table-striped">

    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Department</th>
            <th width="200">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Name</td>

                <td>@item.Department?.Name</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.EmployeeId"
                       class="btn btn-warning btn-sm">Edit</a>

                    <a asp-action="Delete" asp-route-id="@item.EmployeeId"
                       class="btn btn-danger btn-sm">Delete</a>
                </td>

            </tr>
        }
    </tbody>

</table>