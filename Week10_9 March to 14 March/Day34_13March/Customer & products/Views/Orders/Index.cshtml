@model IEnumerable<Customer___products.Models.Order>

<h2>Orders</h2>

<a asp-action="Create" class="btn btn-success mb-3">Place Order</a>

@if (Model != null && Model.Any())
{
    <table class="table table-bordered">

        <thead>
            <tr>
                <th>Customer</th>
                <th>Product</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.Customer?.Name</td>
                    <td>@order.Product?.Name</td>
                    <td>
                        <a asp-action="Delete" asp-route-id="@order.Id" class="btn btn-danger btn-sm">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>
}
else
{
    <p>No orders found</p>
}