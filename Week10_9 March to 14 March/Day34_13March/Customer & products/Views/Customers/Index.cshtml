@model IEnumerable<Customer___products.Models.Customer>

<h2>Customers</h2>

<a asp-action="Create" class="btn btn-success mb-3">Add Customer</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Purchased Products</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var customer in Model)
        {
            <tr>
                <td>@customer.Name</td>

                <td>
                    @(string.IsNullOrEmpty(customer.Email) ? "No Email" : customer.Email)
                </td>

                <td>
                    @(string.IsNullOrEmpty(customer.Phone) ? "No Phone" : customer.Phone)
                </td>

                <td>
                    @if (customer.Orders != null && customer.Orders.Any())
                    {
                        <ul>
                            @foreach (var order in customer.Orders)
                            {
                                <li>@order.Product?.Name</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span>No Products Purchased</span>
                    }
                </td>

                <td>
                    <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-primary btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@customer.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>