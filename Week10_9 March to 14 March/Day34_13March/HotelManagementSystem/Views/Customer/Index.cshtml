@model IEnumerable<HotelManagementSystem.Models.Customer>

<h2>Customers</h2>

<a asp-action="Create" class="btn btn-primary">Add Customer</a>

<table class="table mt-3 table-bordered">

	<tr>
		<th>Name</th>
		<th>Age</th>
		<th>Phone</th>
		<th>Action</th>
	</tr>

	@foreach (var item in Model)
	{
		<tr>
			<td>@item.Name</td>
			<td>@item.Age</td>
			<td>@item.Phone</td>

			<td>
				<a asp-action="Delete"
				   asp-route-id="@item.Id"
				   class="btn btn-danger btn-sm">
					Delete
				</a>
			</td>
		</tr>
	}

</table>