@model HotelManagementSystem.Models.Room

<h2>Delete Room</h2>

<h4>Are you sure you want to delete this room?</h4>

<div class="mb-3">
    <strong>Room Number:</strong> @Model.RoomNumber
</div>

<div class="mb-3">
    <strong>Room Type:</strong> @Model.RoomType
</div>

<div class="mb-3">
    <strong>Price:</strong> @Model.PricePerDay
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>