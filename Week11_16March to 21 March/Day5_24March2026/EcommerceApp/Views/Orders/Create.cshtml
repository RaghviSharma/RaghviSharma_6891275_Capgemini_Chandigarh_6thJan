@model EcommerceApp.Models.Order

<h2>Place Order</h2>

<form id="orderForm" method="post" onsubmit="return false;">
    <div class="mb-2">
        <label>Customer</label>
        <select id="customerId" name="CustomerId" class="form-control" asp-items="ViewBag.Customers"></select>
    </div>

    <div class="mb-2">
        <label>Product</label>
        <select id="productId" name="productId" class="form-control" asp-items="ViewBag.Products"></select>
    </div>

    <div class="mb-2">
        <label>Quantity</label>
        <input id="quantity" type="number" name="quantity" class="form-control" min="1" value="1" />
    </div>

    <div class="mb-2">
        <label>Address</label>
        <input id="address" type="text" name="address" class="form-control" />
    </div>

    <button type="button" id="placeOrderBtn" class="btn btn-success">Place Order (API)</button>
</form>

<div id="orderStatus" class="mt-3"></div>

@section Scripts {
    <script>
        document.getElementById('placeOrderBtn').addEventListener('click', async function () {
            const customerId = parseInt(document.getElementById('customerId').value);
            const productId = parseInt(document.getElementById('productId').value);
            const quantity = parseInt(document.getElementById('quantity').value);
            const address = document.getElementById('address').value;

            const payload = {
                customerId,
                address,
                items: [{ productId, quantity }]
            };

            const response = await fetch('/api/orders', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const statusDiv = document.getElementById('orderStatus');

            if (response.ok) {
                statusDiv.innerHTML = '<div class="alert alert-success">Order created successfully via Web API.</div>';
                setTimeout(() => location.href = '/Orders/Index', 1200);
            } else {
                const text = await response.text();
                statusDiv.innerHTML = '<div class="alert alert-danger">Error: ' + text + '</div>';
            }
        });
    </script>
}