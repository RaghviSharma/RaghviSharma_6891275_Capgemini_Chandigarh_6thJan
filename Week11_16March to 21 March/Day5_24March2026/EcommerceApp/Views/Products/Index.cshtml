@model IEnumerable<EcommerceApp.Models.Product>

<h2>Products</h2>

<a asp-action="Create" class="btn btn-primary mb-2">Add Product</a>

<form method="get" class="mb-3">
    <select name="categoryId" asp-items="ViewBag.Categories" class="form-control">
        <option value="">All Categories</option>
    </select>

    <button type="submit" class="btn btn-secondary mt-2">Filter</button>
</form>

<table class="table table-bordered">
    <tr>
        <th>Name</th>
        <th>Price</th>
        <th>Category</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td>@item.Category?.Name</td>
        </tr>
    }
</table>