@{
    ViewData["Title"] = "Home";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold"> E-Commerce Management System</h1>
    <p class="lead">Manage Customers, Products, Orders and Track Shipments Easily</p>
</div>

<!-- CARDS SECTION -->
<div class="row text-center">

    <!-- Customers -->
    <div class="col-md-3 mb-4">
        <div class="card shadow p-3">
            <h4>Customers</h4>
            <p>Manage customer details</p>
            <a asp-controller="Customers" asp-action="Index" class="btn btn-primary">
                Go to Customers
            </a>
        </div>
    </div>

    <!-- Categories -->
    <div class="col-md-3 mb-4">
        <div class="card shadow p-3">
            <h4>Categories</h4>
            <p>Manage product categories</p>
            <a asp-controller="Categories" asp-action="Index" class="btn btn-success">
                Go to Categories
            </a>
        </div>
    </div>

    <!-- Products -->
    <div class="col-md-3 mb-4">
        <div class="card shadow p-3">
            <h4>Products</h4>
            <p>Add and filter products</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-warning">
                Go to Products
            </a>
        </div>
    </div>

    <!-- Orders -->
    <div class="col-md-3 mb-4">
        <div class="card shadow p-3">
            <h4>Orders</h4>
            <p>Place and track orders</p>
            <a asp-controller="Orders" asp-action="Index" class="btn btn-danger">
                Go to Orders
            </a>
        </div>
    </div>

</div>

<!--  ADMIN SECTION -->
<div class="text-center mt-4">
    <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-dark btn-lg">
        Go to Admin Dashboard
    </a>
</div>