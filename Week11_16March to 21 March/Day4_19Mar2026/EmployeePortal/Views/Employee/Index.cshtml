@model IEnumerable<EmployeePortal.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="container mt-4">

    <h2 class="mb-3">Employee List</h2>

    <!-- Search -->
    <form method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Search by Name or Department" />
            <button class="btn btn-primary" type="submit">Search</button>
        </div>
    </form>

    <!-- Add Button (Admin only) -->
    @if (User.IsInRole("Admin"))
    {
        <a class="btn btn-success mb-3" href="/Employee/Create">Add Employee</a>
    }

    <!-- Table -->
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Department</th>
                <th>Salary</th>
                @if (User.IsInRole("Admin"))
                {
                    <th>Actions</th>
                }
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Department</td>
                        <td>@item.Salary</td>

                        @if (User.IsInRole("Admin"))
                        {
                            <td>
                                <a class="btn btn-sm btn-warning" href="/Employee/Edit/@item.Id">Edit</a>
                                <a class="btn btn-sm btn-danger" href="/Employee/Delete/@item.Id">Delete</a>
                            </td>
                        }
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">No employees found</td>
                </tr>
            }
        </tbody>
    </table>

</div>