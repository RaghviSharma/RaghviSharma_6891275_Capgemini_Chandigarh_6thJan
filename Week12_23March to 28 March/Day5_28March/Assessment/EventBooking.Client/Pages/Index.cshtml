@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="container mt-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h1 class="display-4">🎟️ Event Booking System</h1>
            <p class="lead mt-4">
                Discover amazing events and book your seats instantly. Whether you're looking for concerts, conferences, or sports events, we have it all!
            </p>
            
            <div id="notLoggedIn">
                <p class="text-muted">Get started by creating an account or logging in.</p>
                <div class="gap-3 d-flex">
                    <a href="/Register" class="btn btn-primary btn-lg">📝 Register Now</a>
                    <a href="/Login" class="btn btn-outline-primary btn-lg">🔑 Login</a>
                </div>
            </div>

            <div id="loggedIn" style="display:none;">
                <p class="text-muted">Welcome back! Ready to book your next event?</p>
                <div class="gap-3 d-flex">
                    <a href="/Events" class="btn btn-primary btn-lg">🎫 View Events</a>
                    <a href="/MyBookings" class="btn btn-outline-success btn-lg" id="myBookingsBtn" style="display:none;">📋 My Bookings</a>
                    <a href="/AdminDashboard" class="btn btn-outline-danger btn-lg" id="adminDashBtn" style="display:none;">📊 Admin Dashboard</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-lg bg-light fade-in-up">
                <div class="card-body text-center p-5">
                    <h3>Features</h3>
                    <ul class="list-unstyled mt-4">
                        <li class="mb-3">✅ Easy Event Discovery</li>
                        <li class="mb-3">✅ Instant Booking</li>
                        <li class="mb-3">✅ User Management</li>
                        <li class="mb-3">✅ Admin Dashboard</li>
                        <li class="mb-3">✅ Activity Tracking</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5" />

    <div class="row mt-5">
        <div class="col-md-4 text-center">
            <div class="card border-0 fade-in-up">
                <div class="card-body">
                    <h1 class="text-primary">👥</h1>
                    <h5>For Users</h5>
                    <p class="text-muted">Register, browse events, and book your favorite ones</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="card border-0 fade-in-up">
                <div class="card-body">
                    <h1 class="text-success">🎪</h1>
                    <h5>For Admins</h5>
                    <p class="text-muted">Create events and manage user bookings</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="card border-0 fade-in-up">
                <div class="card-body">
                    <h1 class="text-info">📊</h1>
                    <h5>Analytics</h5>
                    <p class="text-muted">Track user activity and booking statistics</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
window.addEventListener('load', function() {
    const token = localStorage.getItem("token");
    const role = localStorage.getItem("role");

    if (token) {
        document.getElementById("notLoggedIn").style.display = "none";
        document.getElementById("loggedIn").style.display = "block";

        if (role === "User") {
            document.getElementById("myBookingsBtn").style.display = "inline-block";
        } else if (role === "Admin") {
            document.getElementById("adminDashBtn").style.display = "inline-block";
        }
    }
});
</script>