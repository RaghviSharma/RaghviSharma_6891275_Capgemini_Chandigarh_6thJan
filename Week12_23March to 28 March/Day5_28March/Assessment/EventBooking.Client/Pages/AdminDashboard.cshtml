@page
@model AdminDashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1 class="text-center mt-4">📊 Admin Dashboard</h1>

<div class="container mt-5">
    <!-- Unauthorized Message -->
    <div id="unauthorizedMessage" class="alert alert-danger text-center" style="display:none;">
        <h4>⚠️ Access Denied</h4>
        <p>You do not have admin privileges to view this page.</p>
        <a href="/Events" class="btn btn-primary">Back to Events</a>
    </div>

    <!-- Admin Dashboard Content -->
    <div id="adminContent" style="display:none;">
        <!-- Statistics Row -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-white bg-primary fade-in-up">
                    <div class="card-body text-center">
                        <h5 class="card-title">Total Users</h5>
                        <h2 id="totalUsers">-</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-success fade-in-up">
                    <div class="card-body text-center">
                        <h5 class="card-title">Total Events</h5>
                        <h2 id="totalEvents">-</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-info fade-in-up">
                    <div class="card-body text-center">
                        <h5 class="card-title">Total Bookings</h5>
                        <h2 id="totalBookings">-</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-warning fade-in-up">
                    <div class="card-body text-center">
                        <h5 class="card-title">Available Seats</h5>
                        <h2 id="totalSeats">-</h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Management Sections -->
        <div class="row">
            <!-- Events Management -->
            <div class="col-md-6">
                <div class="card shadow mb-4 fade-in-up">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">📅 Events Management</h5>
                    </div>
                    <div class="card-body">
                        <a href="/Events" class="btn btn-primary btn-block mb-2">
                            ➕ Add New Event
                        </a>
                        <button class="btn btn-info btn-block" onclick="loadAllEvents()">
                            📋 View All Events
                        </button>
                        <div id="eventsList" class="mt-3" style="max-height: 400px; overflow-y: auto;"></div>
                    </div>
                </div>
            </div>

            <!-- Bookings Management -->
            <div class="col-md-6">
                <div class="card shadow mb-4 fade-in-up">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">🎫 Bookings Management</h5>
                    </div>
                    <div class="card-body">
                        <button class="btn btn-success btn-block mb-2" onclick="loadAllBookings()">
                            📊 View All Bookings
                        </button>
                        <div id="bookingsList" class="mt-3" style="max-height: 400px; overflow-y: auto;"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- System Actions -->
        <div class="row mt-4">
            <div class="col-md-12">
                <div class="card shadow fade-in-up">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">⚙️ System Actions</h5>
                    </div>
                    <div class="card-body">
                        <button class="btn btn-warning" onclick="exportData()">
                            📥 Export Data
                        </button>
                        <button class="btn btn-danger ms-2" onclick="logout()">
                            🚪 Logout
                        </button>
                        <a href="/Events" class="btn btn-secondary ms-2">
                            ← Back to Events
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-block {
        display: block;
        width: 100%;
    }
    
    .card {
        transition: transform 0.2s;
    }
    
    .card:hover {
        transform: translateY(-5px);
    }
    
    .event-item, .booking-item {
        padding: 10px;
        border-bottom: 1px solid #ddd;
        font-size: 0.9rem;
    }
    
    .event-item:last-child, .booking-item:last-child {
        border-bottom: none;
    }
</style>

<script>
    const API_BASE = "http://localhost:5003/api";
    
    window.onload = function() {
        const token = localStorage.getItem("token");
        const role = localStorage.getItem("role");
        
        if (!token) {
            alert("Please login first");
            window.location.href = "/Login";
            return;
        }
        
        if (role !== "Admin") {
            document.getElementById("unauthorizedMessage").style.display = "block";
            return;
        }
        
        document.getElementById("adminContent").style.display = "block";
        loadDashboardData();
    };
    
    function loadDashboardData() {
        const token = localStorage.getItem("token");
        
        // Load statistics
        fetch(`${API_BASE}/events`, {
            headers: { "Authorization": `Bearer ${token}` }
        })
        .then(r => r.json())
        .then(data => {
            document.getElementById("totalEvents").textContent = data.length;
            const totalSeats = data.reduce((sum, e) => sum + (e.availableSeats || 0), 0);
            document.getElementById("totalSeats").textContent = totalSeats;
        })
        .catch(err => console.error("Events error:", err));
        
        // For now, use mock data for other stats
        document.getElementById("totalUsers").textContent = "5";
        document.getElementById("totalBookings").textContent = "12";
    }
    
    function loadAllEvents() {
        const token = localStorage.getItem("token");
        
        fetch(`${API_BASE}/events`, {
            headers: { "Authorization": `Bearer ${token}` }
        })
        .then(r => r.json())
        .then(data => {
            let html = "<h6>Active Events:</h6>";
            if (data.length === 0) {
                html += "<p class='text-muted'>No events yet.</p>";
            } else {
                data.forEach(event => {
                    html += `<div class="event-item">
                        <strong>${event.title || 'N/A'}</strong>
                        <div class="text-muted small">Date: ${new Date(event.eventDate).toLocaleDateString()}</div>
                        <div class="text-muted small">Available Seats: ${event.availableSeats}</div>
                    </div>`;
                });
            }
            document.getElementById("eventsList").innerHTML = html;
        })
        .catch(err => {
            console.error("Error loading events:", err);
            document.getElementById("eventsList").innerHTML = "<p class='text-danger'>Error loading events</p>";
        });
    }
    
    function loadAllBookings() {
        const token = localStorage.getItem("token");
        
        // This would need an admin endpoint to get all bookings
        fetch(`${API_BASE}/bookings`, {
            headers: { "Authorization": `Bearer ${token}` }
        })
        .then(r => r.json())
        .then(data => {
            let html = "<h6>Recent Bookings:</h6>";
            if (data.length === 0) {
                html += "<p class='text-muted'>No bookings yet.</p>";
            } else {
                data.forEach(booking => {
                    html += `<div class="booking-item">
                        <strong>${booking.eventName || 'Event'}</strong>
                        <div class="text-muted small">Seats: ${booking.seatsBooked}</div>
                        <div class="text-muted small">Date: ${new Date(booking.bookedAt).toLocaleDateString()}</div>
                    </div>`;
                });
            }
            document.getElementById("bookingsList").innerHTML = html;
        })
        .catch(err => {
            console.error("Error loading bookings:", err);
            document.getElementById("bookingsList").innerHTML = "<p class='text-danger'>Error loading bookings</p>";
        });
    }
    
    function exportData() {
        alert("Export feature coming soon!");
    }
    
    function logout() {
        localStorage.removeItem("token");
        localStorage.removeItem("role");
        localStorage.removeItem("username");
        window.location.href = "/Login";
    }
</script>
