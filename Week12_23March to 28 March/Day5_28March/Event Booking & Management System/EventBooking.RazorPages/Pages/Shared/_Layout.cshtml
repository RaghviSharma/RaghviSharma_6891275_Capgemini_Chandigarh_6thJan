@using System.Security.Claims

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eventify</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/">✦ Eventify</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Bookings/MyBookings">Bookings</a>
                    </li>
                    <li class="nav-item" id="authNav">
                        <a class="nav-link" href="/Auth/Login">Sign In</a>
                    </li>
                    <li class="nav-item" id="logoutNav" style="display:none;">
                        <a class="nav-link" href="#" onclick="logout()">Sign Out</a>
                    </li>
                    <li class="nav-item" id="userInfoNav" style="display:none;">
                        <span class="nav-link text-primary" id="userEmail"></span>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main role="main" class="pb-5">
        <div class="container mt-4">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top mt-5 py-4 text-muted" style="border-top: 1px solid var(--border-color) !important; background-color: var(--light-bg);">
        <div class="container">
            <p class="m-0" style="font-size: 0.9rem;">© 2026 Eventify. Event booking made simple.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/auth.js"></script>
    <script src="~/js/api-client.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
