@page
@using EventBooking.RazorPages.Pages
@model IndexModel
@{
    ViewData["Title"] = "Browse Events";
}

<div style="margin-bottom: 3rem;">
    <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">Upcoming Events</h1>
    <p style="color: #6b7280; margin-bottom: 2rem;">Discover and book tickets for amazing events</p>
    
    <input type="text" id="searchInput" class="form-control" placeholder="Search events..." style="max-width: 300px;">
</div>

<div id="loadingSpinner" class="text-center" style="display:none; padding: 3rem 0;">
    <div class="spinner-border" role="status" style="color: var(--primary-color);">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<div id="eventsContainer" class="row" style="display:none;">
    <!-- Events will be loaded here -->
</div>

<div id="noEventsMessage" class="alert alert-info" style="display:none;">
    No events found. Please check back later.
</div>

<div id="errorMessage" class="alert alert-danger" style="display:none;"></div>

<!-- Booking Modal -->
<div class="modal fade" id="bookingModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="border-bottom: 1px solid var(--border-color);">
                <h5 class="modal-title">Book Tickets</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="bookingForm">
                    <input type="hidden" id="eventId" />
                    
                    <div style="margin-bottom: 1rem;">
                        <label class="form-label" style="font-size: 0.85rem; color: #6b7280;">Event</label>
                        <div style="font-weight: 600; font-size: 1.1rem;" id="eventTitle"></div>
                    </div>
                    
                    <div style="margin-bottom: 1rem;">
                        <label class="form-label" style="font-size: 0.85rem; color: #6b7280;">Date & Time</label>
                        <div id="eventDate" style="font-weight: 500;"></div>
                    </div>
                    
                    <div style="margin-bottom: 1rem;">
                        <label class="form-label" style="font-size: 0.85rem; color: #6b7280;">Price per Seat</label>
                        <div id="seatPrice" style="font-weight: 500;"></div>
                    </div>

                    <div style="margin-bottom: 1.5rem;">
                        <label for="seatsBooked" class="form-label">Number of Seats</label>
                        <input type="number" id="seatsBooked" class="form-control" min="1" max="100" required>
                        <small id="seatsError" class="text-danger" style="display:none;"></small>
                    </div>

                    <div style="background-color: var(--light-bg); padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem;">
                        <div style="display: flex; justify-content: space-between;">
                            <span>Total Price:</span>
                            <span id="totalPrice" style="font-weight: 700; color: var(--primary-color);"></span>
                        </div>
                    </div>

                    <div id="bookingError" class="alert alert-danger" style="display:none;"></div>
                </form>
            </div>
            <div class="modal-footer" style="border-top: 1px solid var(--border-color);">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitBooking()">Confirm Booking</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/events.js"></script>
}
